# =============================================================================
# HAIR UP — Supabase 환경 변수 예시
# 이 파일을 복사해 `.env.local` 로 저장한 뒤 값을 채우세요.
# =============================================================================

# Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Project Settings > API > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Project Settings > API > service_role (서버 전용)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# 관리자 비밀번호 재설정 확인 코드 (/admin/forgot-password)
# 없으면 ADMIN_SIGNUP_CODE 를 대신 사용합니다.
ADMIN_RESET_CODE=change-me-to-a-secret

# (선택) 예전 가입 초대 코드 — 재설정 코드 폴백으로도 사용
ADMIN_SIGNUP_CODE=change-me-to-a-secret
